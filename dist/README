For Production

# Minify script.js and detect-touch.js
npm run minify:js

# Development (watch input.css -> output dist/style.css) 
npm run dev:css

# One-time Tailwind build
npm run build:css

# Minify your main.css -> dist/main.min.css
npm run minify:main

# Full production build
npm run build

#to commit files via git
git add .
git commit -m "edit .gitignore"

#push git
git push

#run locally
netlify dev